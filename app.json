{
  "expo": {
    "name": "Motiva ORION Mobile",
    "slug": "motiva-orion-mobile",
    "scheme": "motivaorion",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access to register inspections."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access to register field inspections."
        }
      ]
    ],
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
